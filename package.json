{
  "name": "telegram-crypto-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Telegram Multi-Chain Wallet Manager Bot",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint src/ --ignore-pattern node_modules/",
    "lint:fix": "eslint src/ --ignore-pattern node_modules/ --fix",
    "format": "prettier --write src/ --ignore-pattern node_modules/",
    "test": "node --test tests/*.test.js 2>/dev/null || echo 'No tests found'"
  },
  "keywords": ["telegram", "crypto", "wallet", "bot", "ethereum", "bitcoin", "solana"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "1.98.4",
    "bigint-buffer": "^1.1.5",
    "bip32": "^5.0.1",
    "bip39": "3.1.0",
    "bitcoinjs-lib": "7.0.1",
    "bs58": "6.0.0",
    "canvas": "^3.1.0",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "dotenv": "17.2.3",
    "ecpair": "^3.0.0",
    "ethers": "6.16.0",
    "telegraf": "4.16.3",
    "tiny-secp256k1": "2.2.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}