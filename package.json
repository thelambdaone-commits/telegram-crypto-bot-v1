{
  "name": "telegram-crypto-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Telegram Multi-Chain Wallet Manager Bot",
  "scripts": {
    "precheck": "node scripts/precheck.js",
    "check:polymarket": "node scripts/check-polymarket.js",
    "check:polymarket-history": "node scripts/check-polymarket-history.js",
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint src/ --ignore-pattern node_modules/",
    "lint:fix": "eslint src/ --ignore-pattern node_modules/ --fix",
    "format": "prettier --write src/ --ignore-pattern node_modules/",
    "test": "node --test tests",
    "test:clob": "node --test tests/clob/*.test.js",
    "test:watch": "node --watch --test tests/*.test.js"
  },
  "keywords": [
    "telegram",
    "crypto",
    "wallet",
    "bot",
    "ethereum",
    "bitcoin",
    "solana"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@polymarket/clob-client": "^5.8.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "1.98.4",
    "bip32": "^5.0.1",
    "bip39": "3.1.0",
    "bitcoinjs-lib": "7.0.1",
    "bs58": "6.0.0",
    "canvas": "^3.1.0",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "dotenv": "17.2.3",
    "ecpair": "^3.0.0",
    "ethers": "6.16.0",
    "telegraf": "4.16.3",
    "tiny-secp256k1": "2.2.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=20.18.0"
  }
}
