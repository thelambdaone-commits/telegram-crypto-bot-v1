{
  "name": "telegram-crypto-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Telegram multi-chain crypto wallet bot (15 chains incl. TON) with a keyless, no-KYC cross-chain exchange",
  "scripts": {
    "precheck": "node scripts/precheck.js",
    "check:exports": "node scripts/check-exports.js",
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint src/ --ignore-pattern node_modules/",
    "lint:fix": "eslint src/ --ignore-pattern node_modules/ --fix",
    "format": "prettier --write src/ --ignore-pattern node_modules/",
    "test": "node --test tests",
    "ci": "npm run lint && npm test && npm run precheck",
    "config:check": "node scripts/config-check.js",
    "test:watch": "node --watch --test tests"
  },
  "keywords": [
    "telegram",
    "crypto",
    "wallet",
    "bot",
    "ethereum",
    "bitcoin",
    "solana",
    "ton",
    "monero",
    "no-kyc",
    "exchange",
    "cross-chain"
  ],
  "author": "thelambdaone-commits",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thelambdaone-commits/telegram-crypto-bot-v1.git"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "1.98.4",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.3.0",
    "bip32": "^5.0.1",
    "bip39": "3.1.0",
    "bitcoinjs-lib": "7.0.1",
    "bs58": "6.0.0",
    "bs58check": "^4.0.0",
    "canvas": "^3.1.0",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "dotenv": "17.4.2",
    "ecpair": "^3.0.0",
    "ethers": "6.17.0",
    "monero-ts": "^0.11.10",
    "pm2": "^7.0.3",
    "qrcode": "^1.5.4",
    "socks-proxy-agent": "^10.1.0",
    "telegraf": "4.16.3",
    "tiny-secp256k1": "2.2.4",
    "tronweb": "^6.4.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.9.4"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "overrides": {
    "form-data": "^4.0.6"
  }
}
