# Environment variables (NEVER commit secrets)
.env
.env.local
.env.production
.env.*.local
.env.bak*

# Dependencies
node_modules/

# Data files (contains sensitive encrypted data)
data/*
!data/
!data/.gitkeep

# Session state — never commit (plaintext sessions.json also blocks boot)
sessions.json
sessions.enc

# Logs
logs/
*.log
error_log.txt

# Debug files
debug/

# Build outputs
dist/
build/

# Temporary files
*.tmp
*.temp
.cache/
scratch/

# OS files
.DS_Store
Thumbs.db

# Claude Code: keep shared skills (.claude/skills/), ignore machine-local settings
.claude/settings.local.json

# IDE
.idea/
.vscode/
.codex
.opencode/
*.swp
*.swo

# Zip files
*.zip
crypto-bot.zip

# Output logs
output.log
.gitagent/

# Large media — provisioned out-of-band (kept on the host / cached as a Telegram
# file_id), not stored in git. The welcome video is read from this path at
# runtime (src/bot/handlers/start/index.js), so keep the file on the server.
videoplayback.mp4
*.mp4
