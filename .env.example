# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Encryption key (32 bytes hex - generate with: openssl rand -hex 32)
MASTER_ENCRYPTION_KEY=your_64_char_hex_key_here

# ID de l'admin (Supporte plusieurs IDs séparés par des virgules: ID1,ID2)
ADMIN_CHAT_ID=your_admin_chat_id_here
# ID utilisateur Telegram autorisé à utiliser /admin en privé ou en groupe
ADMIN_USER_ID=your_admin_user_id_here

# RPC & API Endpoints
ETH_RPC_URL=https://eth.llamarpc.com
SOL_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_key
SOL_RPC_FALLBACK_URLS=https://solana-mainnet.g.alchemy.com/v2/your_alchemy_key
BTC_API_URL=https://mempool.space/api
POLYGON_RPC_URL=https://polygon-rpc.com
ARB_RPC_URL=https://arb1.arbitrum.io/rpc
LTC_API_URL=https://litecoinspace.org/api
BCH_API_URL=https://api.blockchain.info/bch
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# CoinGecko API (optionnel, mais requis si l'API publique renvoie 401/429)
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=your_coingecko_demo_key_here
COINGECKO_API_KEY_HEADER=x-cg-demo-api-key

# Monero (XMR) Configuration
XMR_DAEMON_URL=http://node.moneroworld.com:18089
# Wallet RPC (optionnel, requis pour envoyer des transactions)
XMR_WALLET_RPC_URL=
XMR_WALLET_RPC_AUTH=

# Zcash (ZEC) Configuration
ZEC_API_URL=https://api.zcha.in/v2/mainnet
# Zcash node RPC (optionnel, requis pour envoyer des transactions)
ZEC_RPC_URL=
ZEC_RPC_AUTH=

# Tron (TRX + TRC-20) Configuration
TRON_API_URL=https://api.trongrid.io
# Clé API TronGrid (optionnelle mais fortement recommandée pour éviter le rate-limit)
TRON_API_KEY=

# TON (Toncoin) Configuration
TON_RPC_URL=https://toncenter.com/api/v2/jsonRPC
# Clé API TonCenter (optionnelle mais recommandée pour éviter le rate-limit)
TON_API_KEY=

# Tor proxy (optionnel, recommandé pour les transactions privacy coins)
# Format: socks5://127.0.0.1:9050
TOR_PROXY_URL=

# Data storage path (défaut: ./data)
DATA_PATH=./data

# Session timeout in minutes
SESSION_TIMEOUT=5

# Rate limit (requêtes par minute)
RATE_LIMIT=30

# Longueur max d'un message texte entrant (caractères). Au-delà : message
# ignoré (anti-flood). Aucune saisie légitime n'approche cette limite.
MAX_MESSAGE_LENGTH=512

# Échange cross-chain sans KYC (agrégateur Trocador, à la CakeWallet).
# OPTIONNELLE : l'échange marche sans clé (liens AnonPay keyless + devis au taux
# marché). La clé active seulement le devis exact Trocador. Gratuite sur trocador.app.
TROCADOR_API_KEY=
# TROCADOR_API_URL=https://trocador.app/api
# Code de parrainage Trocador (optionnel) — ajouté aux liens AnonPay sans clé.
TROCADOR_REF=

# Daily volume limits for circuit breaker (par défaut dans security.middleware.js)
# DAILY_LIMIT_SOL=10
# DAILY_LIMIT_ETH=0.5
# DAILY_LIMIT_USD=10000
