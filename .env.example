# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Encryption key (32 bytes hex - generate with: openssl rand -hex 32)
MASTER_ENCRYPTION_KEY=your_64_char_hex_key_here

# ID de l'admin (Supporte plusieurs IDs séparés par des virgules: ID1,ID2)
ADMIN_CHAT_ID=your_admin_chat_id_here
# ID utilisateur Telegram autorisé à utiliser /admin en privé ou en groupe
ADMIN_USER_ID=your_admin_user_id_here

# RPC & API Endpoints
ETH_RPC_URL=https://eth.llamarpc.com
SOL_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_key
BTC_API_URL=https://mempool.space/api
POLYGON_RPC_URL=https://polygon-rpc.com
ARB_RPC_URL=https://arb1.arbitrum.io/rpc
LTC_API_URL=https://litecoinspace.org/api
BCH_API_URL=https://api.blockchain.info/bch
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org
# Staking RPC (override for staking operations like Helius)
STAKING_SOL_RPC_URL=

# CoinGecko API (optionnel, mais requis si l'API publique renvoie 401/429)
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=your_coingecko_demo_key_here
COINGECKO_API_KEY_HEADER=x-cg-demo-api-key

# Polymarket Configuration (no API keys - users input via bot)
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_FEED_INTERVAL=60000
POLYMARKET_FEED_ENABLED=false
POLYMARKET_ALERT_CHAT_ID=

# Chemin du .env polymarket-copy-trade mis à jour par le bouton Polymarket (optionnel)
POLYFILL_RS_ENV_PATH=

# Data storage path (défaut: ./data)
DATA_PATH=./data

# Session timeout in minutes
SESSION_TIMEOUT=5

# Rate limit (requêtes par minute)
RATE_LIMIT=30

# Daily volume limits for circuit breaker (par défaut dans security.middleware.js)
# DAILY_LIMIT_SOL=10
# DAILY_LIMIT_ETH=0.5
# DAILY_LIMIT_USD=10000
